{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "start:server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/server"
      },
      "problemMatcher": []
    },
    {
      "label": "start:yjs-server",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}/yjs-server"
      },
      "problemMatcher": []
    },
    {
      "label": "start:client",
      "type": "shell",
      "command": "npm run dev -- --host 0.0.0.0",
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "problemMatcher": []
    },
    {
      "label": "start:all",
      "dependsOn": [
        "start:server",
        "start:yjs-server",
        "start:client"
      ],
      "dependsOrder": "parallel"
    }
  ]
}
